rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Profiles collection
    match /profiles/{profileId} {
      // Anyone can read profiles (public profiles)
      allow read: if true;
      
      // Only authenticated users can write
      allow write: if request.auth != null;
      
      // Users can only update their own profile
      allow update: if request.auth != null 
        && (resource.data.ownerUid == request.auth.uid 
            || (!resource.exists && request.resource.data.ownerUid == request.auth.uid));
      
      // Users can create their own profile
      allow create: if request.auth != null 
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.username is string
        && request.resource.data.username.size() > 0
        && request.resource.data.username.size() <= 24;
      
      // Helper function to validate URL format (basic)
      function isValidUrl(url) {
        return url is string 
          && url.size() > 0 
          && url.size() <= 2048
          && url.matches('https?://.*');
      }
      
      // Helper function to validate link structure
      function isValidLink(link) {
        return link.keys().hasAll(['title', 'url', 'platform'])
          && link.title is string
          && link.title.size() > 0
          && link.title.size() <= 100
          && link.url is string
          && link.url.size() > 0
          && link.url.size() <= 2048
          && link.platform is string
          && link.platform.size() > 0
          && link.platform.size() <= 50
          && isValidUrl(link.url);
      }
      
      // Helper function to validate event structure
      function isValidEvent(event) {
        return event.keys().hasAll(['title', 'contentType', 'platform', 'status'])
          && event.title is string
          && event.title.size() > 0
          && event.title.size() <= 100
          && event.contentType is string
          && event.contentType in ['stream', 'video', 'tournament', 'other']
          && event.platform is string
          && event.platform.size() <= 50
          && event.status is string
          && event.status in ['live', 'scheduled', 'offline']
          && (event.link == null || isValidUrl(event.link))
          && (event.description == null || (event.description is string && event.description.size() <= 1000))
          && (event.image == null || isValidUrl(event.image))
          && (event.thumbnail == null || isValidUrl(event.thumbnail));
      }
      
      // Helper function to validate badge
      function isValidBadge(badge) {
        return badge is string
          && badge.size() > 0
          && badge.size() <= 30;
      }
      
      // Validate username format (alphanumeric and underscore only)
      function isValidUsername(username) {
        return username is string
          && username.size() > 0
          && username.size() <= 24
          && username.matches('^[a-z0-9_]+$');
      }
      
      // Validate data structure
      function isValidProfile() {
        let data = request.resource.data;
        return data.keys().hasAll(['username', 'displayName', 'ownerUid'])
          && isValidUsername(data.username)
          && data.displayName is string
          && data.displayName.size() > 0
          && data.displayName.size() <= 50
          && data.ownerUid is string
          && data.ownerUid == request.auth.uid
          && (data.bio == null || (data.bio is string && data.bio.size() <= 500))
          && (data.avatar == null || isValidUrl(data.avatar))
          && (data.links == null || (
            data.links is list 
            && data.links.size() <= 50
          ))
          && (data.events == null || (
            data.events is list 
            && data.events.size() <= 100
          ))
          && (data.badges == null || (
            data.badges is list 
            && data.badges.size() <= 10
          ));
      }
      
      // Prevent injection attacks by checking for dangerous patterns in strings
      function hasSafeContent(str) {
        return !str.matches('.*<script.*') 
          && !str.matches('.*javascript:.*')
          && !str.matches('.*on\\w+\\s*=.*');
      }
      
      // Enhanced validation with content safety checks
      function isSafeProfile() {
        let data = request.resource.data;
        return isValidProfile()
          && hasSafeContent(data.displayName)
          && (data.bio == null || hasSafeContent(data.bio));
      }
      
      allow create, update: if isSafeProfile();
    }
    
    // Analytics collection - anyone can write for tracking, authenticated users can read
    match /analytics/{analyticsId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow list: if request.auth != null;
    }
    
    // Profile stats collection - aggregated stats
    match /profileStats/{username} {
      allow write: if true; // Allow writes for aggregation
      allow read: if request.auth != null;
    }
    
    // Link stats collection - per-link aggregated stats
    match /linkStats/{linkId} {
      allow write: if true; // Allow writes for aggregation
      allow read: if request.auth != null;
      allow list: if request.auth != null;
    }
    
    // Subscriptions collection - users can only read their own subscription
    match /subscriptions/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only server-side writes allowed via webhooks
    }
  }
}